{% extends "base.html.j2" %}
{% block content %}
<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">{{ profile.profile.title }} · {{ profile.profile.institution }}</p>
    <h1>Gijs Overgoor</h1>
    <p class="lede">{{ profile.profile.short_positioning }}</p>
    <p class="hero-actions">
      <a class="text-link" href="{{ url_for('research') }}">Explore research</a>
      <a class="text-link" href="{{ url_for('cv') }}">View CV</a>
    </p>
  </div>
  <img src="{{ static_url('images/gijs-overgoor.jpg') }}"
       alt="{{ profile.profile.portrait_alt or '' }}">
</section>
<section class="page-section home-about" id="about">
  <p class="eyebrow">About</p>
  <h2>About Me</h2>
  <div class="prose">
    <p>{{ profile.profile.positioning }}</p>
    {{ bio_html | safe }}
  </div>
  <ul class="profile-links">
    {% for link in profile.profile.links %}
    <li><a href="{{ link.url }}">{{ link.label }}</a></li>
    {% endfor %}
  </ul>
</section>
{% endblock %}
